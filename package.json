{
  "name": "agent-mail",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "rm -rf packages/contracts/dist apps/central/dist apps/host/dist && pnpm exec tsc -b tsconfig.json",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @agent-mail/central db:generate",
    "db:migrate": "pnpm --filter @agent-mail/central db:migrate",
    "dev:central": "pnpm --filter @agent-mail/central dev",
    "dev:host": "pnpm --filter @agent-mail/host dev",
    "local:start": "tsx scripts/local-start.ts",
    "local:status": "tsx scripts/local-status.ts",
    "local:stop": "tsx scripts/local-stop.ts",
    "local:bootstrap": "tsx scripts/local-bootstrap.ts",
    "e2e:smoke": "tsx scripts/e2e-smoke.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.8",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
