{
  "name": "agent-mail",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "pnpm --filter @agent-mail/central migrate",
    "dev:central": "pnpm --filter @agent-mail/central dev",
    "dev:host": "pnpm --filter @agent-mail/host dev",
    "dev:web": "pnpm --filter @agent-mail/web dev",
    "local:bootstrap": "node scripts/local-stack.mjs bootstrap",
    "local:start": "node scripts/local-stack.mjs start",
    "local:status": "node scripts/local-stack.mjs status",
    "local:stop": "node scripts/local-stack.mjs stop",
    "test": "pnpm -r test",
    "test:central": "pnpm --filter @agent-mail/central test",
    "test:host": "pnpm --filter @agent-mail/host test",
    "test:web": "pnpm --filter @agent-mail/web test",
    "validate:phase10": "node scripts/validate-phase10.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "playwright": "^1.60.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
