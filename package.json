{
  "name": "agent-mail",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "pnpm --filter @agent-mail/central migrate",
    "dev:central": "pnpm --filter @agent-mail/central dev",
    "test": "pnpm -r test",
    "test:central": "pnpm --filter @agent-mail/central test"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
