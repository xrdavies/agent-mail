{
  "name": "@agent-mail/central",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rm -rf dist && tsc -b tsconfig.json",
    "typecheck": "pnpm --filter @agent-mail/contracts build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @agent-mail/contracts build && vitest run",
    "lint": "pnpm --filter @agent-mail/contracts build && tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@agent-mail/contracts": "workspace:*",
    "@hono/node-server": "^1.14.4",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.5",
    "pg": "^8.16.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.8",
    "drizzle-kit": "^0.31.4"
  }
}
